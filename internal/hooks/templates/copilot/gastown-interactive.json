{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "bash": "{{GT_BIN}} prime --hook",
        "timeoutSec": 30
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "{{GT_BIN}} mail check --inject",
        "timeoutSec": 10
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "bash": "{{GT_BIN}} costs record &",
        "timeoutSec": 10
      }
    ]
  }
}
