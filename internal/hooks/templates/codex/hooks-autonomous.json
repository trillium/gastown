{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} prime --hook && {{GT_BIN}} mail check --inject"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "{{GT_BIN}} costs record >/dev/null 2>&1 &"
          }
        ]
      }
    ]
  }
}
